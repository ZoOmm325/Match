# Copy this file to .env.production and replace every change-me value.

# PostgreSQL
POSTGRES_DB=match
POSTGRES_USER=match
POSTGRES_PASSWORD=change-me-use-a-long-random-password
DATABASE_URL=postgresql+asyncpg://match:change-me-use-a-long-random-password@db:5432/match

# Backend
APP_NAME=JD Major Match API
API_PREFIX=/api
CORS_ORIGINS=["http://your-server-domain-or-ip"]
RUN_MIGRATIONS=true
DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_MODEL=BAAI/bge-m3
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RATE_LIMIT_PER_MINUTE=60

# Public gateway port
HTTP_PORT=80
