# Application
APP_NAME="JD Major Match API"
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL + pgvector
POSTGRES_DB=match
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/match

# Backend
BACKEND_PORT=8000
RUN_MIGRATIONS=true
# DeepSeek API (https://platform.deepseek.com)
# Uncomment and fill your key when LLM-backed services are enabled.
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Embedding model — local BGE model via sentence-transformers (1024-dim)
EMBEDDING_MODEL=BAAI/bge-m3
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RATE_LIMIT_PER_MINUTE=60

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
